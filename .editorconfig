root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.ets]
indent_style = space
indent_size = 2

[*.ts]
indent_style = space
indent_size = 2

[*.json5]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2
